<Window x:Class="Aplikacja_1_Wypozyczalnia_Sklep_Gier.LoginScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aplikacja_1_Wypozyczalnia_Sklep_Gier"
        mc:Ignorable="d"
        Title="Okno logowania" Height="319" Width="300" FontSize="14" Background="MediumPurple">
    <Border Background="White" CornerRadius="20" Margin="20">
        <StackPanel Margin="20">
            <Label Content="Logowanie" Foreground="Black" FontWeight="Bold" FontSize="25" HorizontalAlignment="Center"></Label>
            <Separator></Separator>
            <Label Content="Nazwa użytkownika :" FontWeight="Bold" Foreground="Black"></Label>
            <TextBox Name="txtUsername" Background="LightYellow" Foreground="Black" FontFamily="18"></TextBox>
            <Label Content="Hasło :" FontWeight="Bold" Foreground="Black"></Label>
            <PasswordBox Name="txtPassword" Background="LightYellow" Foreground="Black" FontFamily="18"></PasswordBox>
            <Button Name="btnSubmit" Click="btnSubmit_Click" Content="Potwierdź" Margin="60 10" FontWeight="Bold" Background="MediumPurple" Foreground="Black" FontFamily="18"></Button>
        </StackPanel>
    </Border>
</Window>
